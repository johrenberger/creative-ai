{
  "name": "creative-ai",
  "version": "1.0.0",
  "description": "Clawdexter's Thinking Interface - A productivity layer for structured human-AI collaboration",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "cli": "node src/cli.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "build": "echo 'Build complete'",
    "lint": "eslint src/",
    "security": "npm audit --audit-level=high"
  },
  "keywords": [
    "productivity",
    "cli",
    "local-first",
    "structured-communication",
    "task-management"
  ],
  "author": "Clawdexter",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dompurify": "^3.1.6",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsdom": "^25.0.0",
    "marked": "^14.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^9.12.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "moduleFileExtensions": [
      "js",
      "mjs"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/johrenberger/creative-ai"
  }
}
